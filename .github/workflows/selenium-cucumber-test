name: Demo Web Shop Automation CI

on:
  push:
    branches: [ main, master, develop ]
  pull_request:
    branches: [ main, master ]
  schedule:
    - cron: '0 6 * * *'
  workflow_dispatch:

jobs:
  test:
    name: Run Selenium Cucumber Tests
    runs-on: ubuntu-latest

    strategy:
      matrix:
        browser: [chrome]

    steps:
      - name: Checkout Repository
        uses: actions/checkout@v3

      - name: Set up JDK 11
        uses: actions/setup-java@v4
        with:
          java-version: '11'
          distribution: 'temurin'

      - name: Cache Maven dependencies
        uses: actions/cache@v3
        with:
          path: ~/.m2
          key: ${{ runner.os }}-m2-${{ hashFiles('**/pom.xml') }}
          restore-keys: ${{ runner.os }}-m2

      - name: Cache WebDriver Manager
        uses: actions/cache@v4
        with:
          path: ~/.cache/webdrivermanager
          key: ${{ runner.os }}-webdrivermanager

      # Install Chrome 140 (build 140) from Chrome for Testing
      - name: Install Chrome 140
        run: |
          CHROME_VERSION="140.0.7339.0"
          CHROME_URL="https://storage.googleapis.com/chrome-for-testing-public/${CHROME_VERSION}/linux64/chrome-linux64.zip"
          wget -q "$CHROME_URL" -O chrome.zip
          unzip -q chrome.zip
          sudo mkdir -p /opt/chrome
          sudo mv chrome-linux64 /opt/chrome
          sudo ln -sf /opt/chrome/chrome-linux64/chrome /usr/local/bin/google-chrome
          google-chrome --version

      - name: Display versions
        run: |
          java -version
          mvn --version
          google-chrome --version

      # Run tests with Chrome headless arguments
      - name: Run Selenium Tests
        run: mvn clean test
        env:
          BROWSER: ${{ matrix.browser }}
          CI: true
          HEADLESS: true
          CHROME_OPTIONS: "--headless --no-sandbox --disable-dev-shm-usage --disable-gpu --window-size=1920,1080"

      - name: Upload Extent Report
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: extent-report-${{ matrix.browser }}-${{ github.run_number }}
          path: test-output/ExtentReports/*.html
          retention-days: 30

      - name: Upload Cucumber Report
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: cucumber-reports-${{ matrix.browser }}-${{ github.run_number }}
          path: |
            target/cucumber-reports/
            target/cucumber-html-reports/
          retention-days: 30

      - name: Upload Screenshots
        if: failure()
        uses: actions/upload-artifact@v4
        with:
          name: failure-screenshots-${{ github.run_number }}
          path: test-output/Screenshots/
          retention-days: 15
